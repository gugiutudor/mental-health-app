{
  "name": "mental-health-app",
  "version": "1.0.0",
  "description": "Aplicație de monitorizare a sănătății mentale",
  "main": "src/index.js",
  "scripts": {
    "start": "cd server && node src/index.js",
    "dev": "cd server && nodemon src/index.js",
    "test": "jest --config=jest.config.js",
    "test:watch": "jest --config=jest.config.js --watch",
    "test:client": "cd client && npm test",
    "test:all": "npm test && npm run test:client && npm run test:integration && npm run test:e2e",
    "test:integration": "jest --config=jest.config.js --testPathPattern=src/tests/integration",
    "test:e2e": "mocha tests/e2e/userJourney.test.js",
    "test:coverage": "jest --config=jest.config.js --coverage",
    "test:client:coverage": "cd client && npm run test:coverage",
    "setup:test": "npm install && cd client && npm install",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:test": "./run-tests-docker.sh",
    "docker:test:e2e": "./run-e2e-tests-docker.sh",
    "docker:test:all": "./run-all-docker-tests.sh",
    "docker:coverage": "./generate-coverage-report.sh"
  },
  "keywords": [
    "sănătate mentală",
    "monitorizare",
    "wellbeing"
  ],
  "author": "Gugiu Tudor",
  "license": "ISC",
  "dependencies": {
    "apollo-server-express": "^3.12.0",
    "apollo-server-testing": "^2.25.3",
    "bcrypt": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "graphql": "^15.8.0",   
    "joi": "^17.9.1",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.0.3"
  },
  "devDependencies": {
    "chai": "^4.3.4",
    "eslint": "^8.37.0",
    "jest": "^29.5.0",
    "mocha": "^10.2.0",
    "mongodb-memory-server": "^8.12.2",
    "nodemon": "^2.0.22",
    "selenium-webdriver": "^4.8.1",
    "supertest": "^6.3.3"
  }
}