FROM node:18-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm install

# Copy the rest of the application code
COPY . .

# Install test-specific dependencies
RUN npm install -D jest mongodb-memory-server supertest

# Command to run integration tests (will be overridden by docker-compose)
CMD ["npm", "run", "test:integration"]